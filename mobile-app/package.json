{
  "name": "slp-mobile-wrapper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "web": "npx http-server www -p 5173",
    "build:web": "cp -R www-dist www || true",
    "cap:init": "npx cap init slp-mobile-wrapper com.yourcompany.slp 'SLP Mobile Wrapper'",
    "cap:add-android": "npx cap add android",
    "cap:add-ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "http-server": "^14.1.1"
  }
}
